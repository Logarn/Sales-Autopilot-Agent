{
  "name": "upwork-agent",
  "version": "1.0.0",
  "description": "Slack-controlled Upwork application agent with browser search, proposal drafting, and guardrails",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "npm run worker",
    "worker": "node dist/index.js",
    "worker:dev": "tsx src/index.ts",
    "scheduler": "node dist/scheduler.js",
    "scheduler:dev": "tsx src/scheduler.ts",
    "run:once": "node dist/index.js --run-once",
    "health": "node dist/health.js",
    "report": "node dist/applications.js",
    "analytics": "node dist/applications.js --analytics",
    "test:fetch": "tsx src/fetcher.ts",
    "test:slack": "tsx src/slack.ts",
    "slack:preview": "tsx src/slackPreview.ts",
    "slack:conversation": "tsx src/slackConversation.ts",
    "slack:socket": "tsx src/slackSocket.ts",
    "test:slack-socket": "tsx src/slackSocket.test.ts",
    "test:capture": "tsx src/browserCapture.test.ts",
    "test:e2e-dry-run": "tsx src/e2eDryRun.test.ts",
    "test:browser-session-scripts": "bash scripts/browser-session-scripts.test.sh",
    "test:run-once": "tsx src/index.ts --run-once",
    "test:health": "tsx src/health.ts",
    "test:slack-flag": "tsx src/index.ts --test-slack",
    "add:manual-job": "tsx src/manual.ts",
    "capture:job": "tsx src/manual.ts",
    "normalize:capture": "tsx src/normalizeCli.ts",
    "app:status": "tsx src/applications.ts --set-status",
    "app:note": "tsx src/applications.ts --add-note",
    "app:notes": "tsx src/applications.ts --notes",
    "app:apply": "tsx src/applications.ts --record-submission",
    "app:analytics": "tsx src/applications.ts --analytics",
    "app:capture": "tsx src/capture.ts",
    "app:report": "tsx src/applications.ts",
    "knowledge:add": "tsx src/knowledge.ts",
    "knowledge:video": "tsx src/knowledge.ts --video",
    "portfolio:upsert": "tsx src/knowledge.ts --portfolio-upsert",
    "proof:check": "tsx src/proofAssets.ts",
    "assets:check": "tsx src/proofAssets.ts",
    "browser:enqueue": "tsx src/browserQueue.ts --enqueue",
    "browser:list": "tsx src/browserQueue.ts --list",
    "browser:update": "tsx src/browserQueue.ts --update",
    "browser:retry": "tsx src/browserQueue.ts --retry",
    "browser:search": "tsx src/browserSearch.ts",
    "browser:search:prod": "node dist/browserSearch.js",
    "browser:session": "tsx src/browserSessionCli.ts --start",
    "browser:session:service": "bash scripts/start-browser-session.sh",
    "browser:session:check": "bash scripts/check-browser-session.sh",
    "browser:cdp:check": "tsx src/browserSessionCli.ts --check",
    "browser:session:clear": "tsx src/browserSessionCli.ts --clear",
    "browser:session:recover-stale": "tsx src/browserSessionCli.ts --recover-stale",
    "browser:tool": "tsx src/browserToolCli.ts",
    "browser:worker": "tsx src/browserWorker.ts",
    "browser:worker:controlled": "tsx src/browserWorker.ts --controlled 2",
    "worker:run-once": "tsx src/browserWorker.ts --controlled 2",
    "browser:readiness": "tsx src/browserWorker.ts --readiness",
    "browser:worker:prod": "node dist/browserWorker.js",
    "agent:run": "tsx src/leadEngine.ts --run",
    "agent:run-once": "tsx src/leadEngine.ts --run-once",
    "agent:run-once:dry": "tsx src/leadEngine.ts --run-once --dry-run",
    "agent:validate": "tsx src/leadEngine.ts --validate",
    "agent:status": "tsx src/leadEngine.ts --status",
    "validate:promotion": "bash scripts/validate-promotion.sh",
    "validate:contabo-env": "bash scripts/validate-contabo-env.sh",
    "preflight:contabo": "bash scripts/preflight-contabo.sh",
    "production:smoke": "bash scripts/production-smoke.sh",
    "mayor:production-check": "bash scripts/mayor-production-check.sh",
    "memori:smoke": "tsx src/memoriDiagnosticsCli.ts smoke",
    "memori:diagnose": "tsx src/memoriDiagnosticsCli.ts diagnose",
    "discovery:run-once": "tsx src/discoveryScheduler.ts --run-once",
    "discovery:scheduler": "tsx src/discoveryScheduler.ts --scheduler",
    "skills:list": "tsx src/skills.ts list",
    "skills:read": "tsx src/skills.ts read"
  },
  "keywords": [
    "upwork",
    "agent",
    "slack",
    "notifier",
    "klaviyo",
    "shopify"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@slack/bolt": "^4.7.2",
    "@slack/webhook": "^7.0.4",
    "better-sqlite3": "^12.4.1",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "node-cron": "^4.2.1",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
