# Slack V0 proposal packets use only an incoming webhook.
# No Slack app, OAuth token, or socket-mode token is required for V0.
SLACK_CHANNEL_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Slack inbound conversation placeholders. local_cli works without credentials;
# events/socket_mode/polling require a Slack app or bot token and are documented in README/deployment.
SLACK_INBOUND_MODE=local_cli
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_POLL_CHANNEL_ID=
APIFY_API_TOKEN=your_apify_token_here
# Optional URL button for a manual quick-bid/proposal template.
QUICK_BID_TEMPLATE_URL=

# Polling / autonomous scheduler
CRON_SCHEDULE=*/5 * * * *
DAILY_SUMMARY_CRON=0 8 * * *
SCHEDULER_INTERVAL_MS=300000
HEARTBEAT_STALE_AFTER_MS=900000
HEALTH_ALERT_COOLDOWN_MS=3600000
TIMEZONE=Africa/Nairobi

# Filtering
MIN_SCORE_TO_NOTIFY=4
MIN_SCORE_HIGH=8

# Runtime
LOG_LEVEL=info
DB_PATH=./data/jobs.db
PROFILE_CONFIG_PATH=./profile/profile.json
PORTFOLIO_CONFIG_PATH=./profile/portfolio.json
MANUAL_JOBS_CONFIG_PATH=./config/manual-jobs.json
CONNECTS_RULES_CONFIG_PATH=./profile/connects-rules.json
MAX_DESCRIPTION_LENGTH=300
ENABLE_LOW_MATCH_DIGEST=false

# Optional LLM normalization (disabled unless explicitly enabled and keyed)
LLM_NORMALIZATION_ENABLED=false
LLM_PROVIDER=openai-compatible
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1

# Browser search / queue / worker (safe by default)
# Apply preparation requires an approved application and always stops before final submit.
# Preview locally with: npm run browser:enqueue -- --apply-preview --job-id <approved-job-id>
BROWSER_SEARCH_ENABLED=false
BROWSER_SEARCH_INTERVAL_MS=300000
BROWSER_SEARCH_MAX_JOBS_PER_QUERY=10
BROWSER_SEARCH_FRESHNESS_WINDOW_MINUTES=60
# Optional '|' separated plain queries; defaults to SEARCH_QUERIES/config queries when unset.
# BROWSER_SEARCH_QUERIES=Klaviyo Shopify email marketing|Klaviyo retention marketing
# Optional '|' separated Upwork search URLs; non-Upwork URLs are ignored.
# BROWSER_SEARCH_URLS=https://www.upwork.com/nx/search/jobs/?q=Klaviyo&sort=recency
BROWSER_WORKER_ENABLED=false
BROWSER_HEADLESS=true
BROWSER_USER_DATA_DIR=./data/browser-profile
BROWSER_DRY_RUN=true
BROWSER_ARTIFACT_DIR=./data/browser-artifacts
BROWSER_ACTION_LIMIT=5

# Optional tuning
FETCH_RETRY_ATTEMPTS=3
SLACK_RETRY_ATTEMPTS=3
FEED_DELAY_MS=2000
SLACK_DELAY_MS=2000

# Query sources
# Option A: provide '|' separated queries in env:
# SEARCH_QUERIES=Klaviyo Shopify email marketing|Klaviyo retention marketing
#
# Option B: store in JSON (default path ./config/queries.json)
# QUERIES_CONFIG_PATH=./config/queries.json
