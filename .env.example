# Slack outbound is always required.
# Socket Mode and inbound thread commands are optional and need Slack app credentials.
SLACK_CHANNEL_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# local_cli works without extra credentials.
# socket_mode requires SLACK_BOT_TOKEN, SLACK_APP_TOKEN, and allowed channel IDs.
SLACK_INBOUND_MODE=local_cli
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SOCKET_MODE_ENABLED=false
# Comma- or pipe-separated list of Slack channel IDs allowed for Socket Mode commands.
SLACK_ALLOWED_CHANNEL_IDS=
# Slack file intake requires the bot token plus Slack files:read scope.
SLACK_FILE_MAX_BYTES=10485760
SLACK_FILE_ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.webp
SLACK_POLL_CHANNEL_ID=
APIFY_API_TOKEN=your_apify_token_here
# Optional URL button for a manual quick-bid/proposal template.
QUICK_BID_TEMPLATE_URL=

# Polling / health / runtime cadence
CRON_SCHEDULE=*/5 * * * *
DAILY_SUMMARY_CRON=0 8 * * *
SCHEDULER_INTERVAL_MS=300000
HEARTBEAT_STALE_AFTER_MS=900000
HEALTH_ALERT_COOLDOWN_MS=3600000
TIMEZONE=Africa/Nairobi

# Filtering
MIN_SCORE_TO_NOTIFY=4
MIN_SCORE_HIGH=8

# Runtime
# For Contabo deployment, copy this file to .env and switch the state paths to /opt/upwork-agent/shared/...
LOG_LEVEL=info
DB_PATH=./data/jobs.db
PROFILE_CONFIG_PATH=./profile/profile.json
PORTFOLIO_CONFIG_PATH=./profile/portfolio.json
MANUAL_JOBS_CONFIG_PATH=./config/manual-jobs.json
SAVED_SEARCHES_CONFIG_PATH=./config/saved-searches.json
CONNECTS_RULES_CONFIG_PATH=./profile/connects-rules.json
# Production proof files should live outside Git.
# On Contabo, use /opt/upwork-agent/shared/proof-assets and keep manifest paths repo-style, e.g. profile/attachments/example.pdf.
PROOF_ASSET_ROOT=
MAX_DESCRIPTION_LENGTH=300
ENABLE_LOW_MATCH_DIGEST=false

# Optional LLM normalization (disabled unless explicitly enabled and keyed)
LLM_NORMALIZATION_ENABLED=false
LLM_PROVIDER=openai-compatible
OPENAI_API_KEY=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
LMSTUDIO_API_KEY=
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen/qwen3.5-9b
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
MOONSHOT_MODEL=kimi-k2.5
LLM_REQUEST_TIMEOUT_MS=30000

# Optional LLM job intelligence parser (disabled by default; defaults to xAI/Grok when XAI_API_KEY is set)
JOB_INTELLIGENCE_ENABLED=false
JOB_INTELLIGENCE_PROVIDER=xai
JOB_INTELLIGENCE_MODEL=grok-4.3
JOB_INTELLIGENCE_TEMPERATURE=0

# Optional user-facing Slack copywriter (enabled by default but safely falls back without a Moonshot/Kimi key)
SLACK_COPY_LLM_ENABLED=true
SLACK_COPY_PROVIDER=kimi
SLACK_COPY_MODEL=kimi-k2.5
SLACK_COPY_TEMPERATURE=0.25

# Browser search / queue / worker (safe by default)
# Apply preparation requires an approved application and always stops before final submit.
# Preview locally with: npm run browser:enqueue -- --apply-preview --job-id <approved-job-id>
BROWSER_SEARCH_ENABLED=false
BROWSER_SEARCH_INTERVAL_MS=300000
BROWSER_SEARCH_MAX_JOBS_PER_QUERY=10
BROWSER_SEARCH_FRESHNESS_WINDOW_MINUTES=60
# Optional '|' separated plain queries; defaults to SEARCH_QUERIES/config queries when unset.
# BROWSER_SEARCH_QUERIES=Klaviyo Shopify email marketing|Klaviyo retention marketing
# Optional '|' separated Upwork search URLs; non-Upwork URLs are ignored.
# BROWSER_SEARCH_URLS=https://www.upwork.com/nx/search/jobs/?q=Klaviyo&sort=recency
BROWSER_WORKER_ENABLED=false
BROWSER_HEADLESS=true
# launch = worker launches the browser profile directly; cdp = worker connects to an already-running visible Chrome session.
# Contabo should use cdp so manual login and challenge handling happen in the server browser session.
BROWSER_SESSION_MODE=cdp
BROWSER_CDP_URL=http://127.0.0.1:9222
BROWSER_USER_DATA_DIR=./data/browser-profile
# Optional; when unset the worker searches common local Chrome/Chromium install paths.
BROWSER_CHROME_EXECUTABLE_PATH=
BROWSER_DRY_RUN=true
BROWSER_ARTIFACT_DIR=./data/browser-artifacts
BROWSER_ACTION_LIMIT=5
# Live browser mode defaults to one action per run unless explicitly raised.
BROWSER_LIVE_ACTION_LIMIT=1
# Suppress repeated manual-attention Slack alerts for the same browser/session issue.
BROWSER_MANUAL_ATTENTION_ALERT_COOLDOWN_MS=3600000
# More than 2 challenge/manual-attention events in 60 minutes marks the browser session unhealthy.
BROWSER_SESSION_CHALLENGE_THRESHOLD=2
BROWSER_SESSION_CHALLENGE_WINDOW_MS=3600000
# Always-on lead engine (safe by default; validate before enabling on a server)
AGENT_ENGINE_ENABLED=false
AGENT_ENGINE_INTERVAL_MS=300000
AGENT_ENGINE_JITTER_PCT=0.2
AGENT_ENGINE_QUEUE_CAP=25
AGENT_ENGINE_MAX_WORKER_ACTIONS=2
AGENT_ENGINE_STATE_PATH=./data/agent-engine-state.json
# Future browser search cadence should stay slow and jittered; no overlapping/retry loops after challenges.
BROWSER_SEARCH_JITTER_MIN_MS=480000
BROWSER_SEARCH_JITTER_MAX_MS=840000

# Optional tuning
FETCH_RETRY_ATTEMPTS=3
SLACK_RETRY_ATTEMPTS=3
FEED_DELAY_MS=2000
SLACK_DELAY_MS=2000

# Query sources
# Option A: provide '|' separated queries in env:
# SEARCH_QUERIES=Klaviyo Shopify email marketing|Klaviyo retention marketing
#
# Option B: store in JSON (default path ./config/queries.json)
# QUERIES_CONFIG_PATH=./config/queries.json
